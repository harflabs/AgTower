# AgTower environment variables.
#
# Local development and `pnpm build` need NONE of these — they are only used for
# signed/notarized release builds and the auto-updater. The GitHub Actions release
# workflow (.github/workflows/release-macos.yml) reads them from repository secrets;
# 1Password is the source of truth. Copy this file to `.env` to set them locally.
#
# `.env` and `.env.*` are gitignored; only this `.env.example` template is committed.

# --- Local macOS bundling (optional) -------------------------------------------------
# Apple code-signing identity for `pnpm build:mac` / `pnpm build:dmg`.
# Defaults to "-" (ad-hoc signing) when unset.
APPLE_SIGNING_IDENTITY=-

# --- Apple Developer ID signing + notarization (release only) ------------------------
APPLE_CERTIFICATE=
APPLE_CERTIFICATE_PASSWORD=
KEYCHAIN_PASSWORD=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# --- Tauri auto-updater signing (release only) ---------------------------------------
# minisign private key + password. Rotate per the "Rotating the Tauri updater signing
# key" section in README.md. The matching public key lives in src-tauri/tauri.conf.json.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# --- Dev server (optional) -----------------------------------------------------------
# Host to bind the Vite dev server to (e.g. for testing on a physical device).
TAURI_DEV_HOST=
