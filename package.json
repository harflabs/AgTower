{
  "name": "agtower",
  "private": true,
  "version": "1.0.0",
  "description": "Mission control for AI coding agents across multiple repositories.",
  "license": "MIT",
  "author": "Harf Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harflabs/AgTower.git"
  },
  "homepage": "https://github.com/harflabs/AgTower#readme",
  "bugs": {
    "url": "https://github.com/harflabs/AgTower/issues"
  },
  "packageManager": "pnpm@11.0.8",
  "type": "module",
  "scripts": {
    "check": "pnpm lint && pnpm lint:dead && pnpm test && pnpm build && pnpm check:rust",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml",
    "dev": "vite",
    "build": "tsc && tsc -p tsconfig.node.json && vite build",
    "build:mac": "APPLE_SIGNING_IDENTITY=\"${APPLE_SIGNING_IDENTITY:--}\" tauri build --bundles app --config '{\"bundle\":{\"createUpdaterArtifacts\":false}}'",
    "build:dmg": "APPLE_SIGNING_IDENTITY=\"${APPLE_SIGNING_IDENTITY:--}\" tauri build --bundles app,dmg --config '{\"bundle\":{\"createUpdaterArtifacts\":false}}' && node scripts/rename-dmg.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "tauri": "tauri",
    "lint": "biome check src/",
    "lint:dead": "knip --include files,dependencies,unlisted,exports,types --include-entry-exports",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.16.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
